# Supabase project — used for Google sign-in and mapping each signed-in
# user to their own Google Sheet. Get these from your Supabase project's
# Settings → API page. Safe to expose client-side (the anon key is public
# by design; row-level security in supabase/profiles.sql does the real
# access control).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Strava — optional. Only VITE_STRAVA_CLIENT_ID is needed client-side (it's
# public by design, embedded in the OAuth authorize URL). The matching
# STRAVA_CLIENT_ID / STRAVA_CLIENT_SECRET / SUPABASE_SERVICE_ROLE_KEY are
# server-only secrets set directly in Vercel's dashboard, never in this file.
VITE_STRAVA_CLIENT_ID=your-strava-client-id
