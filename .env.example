# Supabase project — used for Google sign-in, each user's own training
# program (profiles.routine_config), and their logged workouts (the
# sessions table). Get these from your Supabase project's Settings → API
# page. Safe to expose client-side (the anon key is public by design;
# row-level security in supabase/*.sql does the real access control).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Strava — optional. Only VITE_STRAVA_CLIENT_ID is needed client-side (it's
# public by design, embedded in the OAuth authorize URL). The matching
# STRAVA_CLIENT_ID / STRAVA_CLIENT_SECRET / SUPABASE_SERVICE_ROLE_KEY are
# server-only secrets set directly in Vercel's dashboard, never in this file.
VITE_STRAVA_CLIENT_ID=your-strava-client-id

# AI Coach chat — optional, owner-only feature. VITE_CHAT_OWNER_EMAIL is
# client-safe and UX-only (it just hides the Coach tab for everyone else);
# it is NOT a security boundary. The real gate is the server-only
# CHAT_OWNER_USER_ID env var, along with ANTHROPIC_API_KEY and the optional
# CHAT_DAILY_LIMIT / CHAT_WINDOW_LIMIT — all set directly in Vercel's
# dashboard, never in this file.
VITE_CHAT_OWNER_EMAIL=you@example.com
