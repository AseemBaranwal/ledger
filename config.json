        },
        {
          "n": "Plank",
          "d": "3 × 45s",
          "cue": "Ribs down, glutes squeezed, straight line. No sagging hips."
        },
        {
          "n": "Dead Bug",
          "d": "3 × 10 / side",
          "cue": "Low back pinned flat to the floor. Slow, opposite arm + leg."
        },
        {
          "n": "Side Plank",
          "d": "2 × 30s / side",
          "cue": "Stack the hips, don't let them drop. Anti-rotation for the obliques."
        }
      ]
    },
